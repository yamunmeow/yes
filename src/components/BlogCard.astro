---
export interface Props {
  title: string;
  date: string;
  excerpt: string;
  tags: string[];
  slug: string;
}

const { title, date, excerpt, tags, slug } = Astro.props;
---

<article class="blog-card card">
  <div class="post-meta">
    📅 {date}
    {tags.map(tag => <span class="tag">#{tag}</span>)}
  </div>
  <h3 class="post-title">{title}</h3>
  <p class="post-excerpt">{excerpt}</p>
  <a href={`/blog/${slug}`} class="btn btn-sm">read more →</a>
</article>