---
export interface Props {
  title: string;
  description: string;
  publisher: string;
  year: string;
  slug: string;
}

const { title, description, publisher, year, slug } = Astro.props;
---

<div class="publication-card card">
  <h3>📖 {title}</h3>
  <p>{description}</p>
  <small>{publisher} • {year}</small>
  <div style="margin-top: 12px;">
    <a href={`/publications/${slug}`} class="btn btn-sm">details</a>
  </div>
</div>