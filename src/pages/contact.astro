---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="hero">
    <h1>contact</h1>
    <p>let's create something beautiful together</p>
  </div>
  
  <div class="card" style="max-width: 600px; margin: 2rem auto;">
    <h2>📫 send a message</h2>
    <form style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem;">
      <input type="text" placeholder="your name" class="search-input" style="width: 100%;" />
      <input type="email" placeholder="your email" class="search-input" style="width: 100%;" />
      <textarea placeholder="your message" rows="5" class="search-input" style="width: 100%; resize: vertical;"></textarea>
      <button class="btn" style="align-self: flex-start;">send message →</button>
    </form>
    <hr />
    <p><strong>📧 email:</strong> hello@makeitgolden.co.uk</p>
    <p><strong>📷 instagram:</strong> @makeitgolden</p>
    <p><strong>🐦 twitter:</strong> @makeitgolden</p>
  </div>
</BaseLayout>