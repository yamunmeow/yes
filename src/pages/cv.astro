---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="hero">
    <h1>cv & experience</h1>
    <p>selected achievements and exhibitions</p>
  </div>
  
  <div class="card" style="max-width: 800px; margin: 2rem auto;">
    <h2>📚 education</h2>
    <div style="margin: 1rem 0;">
      <p><strong>2020-2023</strong> - MFA in Visual Arts, Royal College of Art, London</p>
      <p><strong>2016-2019</strong> - BA in Fine Arts, University of Arts London</p>
    </div>
    
    <hr />
    
    <h2>🎨 exhibitions</h2>
    <div style="margin: 1rem 0;">
      <p><strong>2025</strong> - "Soft Echoes" (Solo), The Pastel Gallery, London</p>
      <p><strong>2024</strong> - "Dreamscapes" (Group), Digital Art Festival, Berlin</p>
      <p><strong>2023</strong> - "New Voices" (Group), Saatchi Gallery, London</p>
    </div>
    
    <hr />
    
    <h2>📝 publications</h2>
    <div style="margin: 1rem 0;">
      <p><strong>2025</strong> - "Soft Narratives" in Art Journal Quarterly</p>
      <p><strong>2024</strong> - "The Digital Palette" chapter in Creative Press</p>
    </div>
    
    <hr />
    
    <h2>🏆 awards</h2>
    <div style="margin: 1rem 0;">
      <p><strong>2024</strong> - Emerging Artist Grant, Arts Council England</p>
      <p><strong>2023</strong> - Best Illustration Award, London Design Festival</p>
    </div>
  </div>
</BaseLayout>