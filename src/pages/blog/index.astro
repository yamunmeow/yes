---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const allPosts = [
  { title: "Whispers of Watercolor", date: "Apr 10, 2025", excerpt: "Exploring soft gradients and the emotion of bleeding pigments.", tags: ["art", "watercolor"], slug: "whispers-watercolor" },
  { title: "Digital Dreamscapes", date: "Mar 28, 2025", excerpt: "How I create dreamy pastel illustrations using Procreate.", tags: ["digital", "tutorial"], slug: "digital-dreamscapes" },
  { title: "Finding Creative Flow", date: "Mar 15, 2025", excerpt: "Mindfulness routines that boost artistic productivity.", tags: ["creativity", "wellness"], slug: "creative-flow" },
  { title: "Exhibition Recap: 'Soft Echoes'", date: "Feb 28, 2025", excerpt: "Photos and thoughts from my first solo show.", tags: ["exhibition", "art"], slug: "soft-echoes" },
  { title: "Palette Exploration: Pink & Yellow", date: "Feb 10, 2025", excerpt: "Why these two hues became my signature.", tags: ["color", "inspiration"], slug: "pink-yellow-palette" }
];
---

<BaseLayout>
  <div class="hero">
    <h1>blog</h1>
    <p>thoughts, tutorials, and creative explorations</p>
  </div>
  
  <div class="grid-blog">
    {allPosts.map(post => <BlogCard {...post} />)}
  </div>
</BaseLayout>