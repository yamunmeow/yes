---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <div class="hero">
    <h1>about me</h1>
    <p>artist, writer, dreamer</p>
  </div>
  
  <div class="card" style="max-width: 800px; margin: 2rem auto;">
    <h2>✨ hello, i'm golden ✨</h2>
    <p style="margin: 1rem 0;">I'm an artist and writer based in a cozy corner of the world, creating dreamy pastel worlds through illustration and words.</p>
    <p style="margin: 1rem 0;">My work explores themes of softness, nostalgia, and the gentle magic of everyday moments. When I'm not painting or writing, you can find me sipping tea, collecting vintage books, or wandering through gardens.</p>
    <p style="margin: 1rem 0;">This space is my digital garden—a place to share my creative journey, thoughts, and inspirations with you.</p>
    <hr />
    <p><strong>📧 get in touch:</strong> hello@makeitgolden.co.uk</p>
  </div>
</BaseLayout>