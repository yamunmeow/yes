---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PublicationCard from '../components/PublicationCard.astro';

// Content collections (would typically come from content layer)
const blogPosts = [
  { id: 1, title: "Whispers of Watercolor", date: "Apr 10, 2025", excerpt: "Exploring soft gradients and the emotion of bleeding pigments.", tags: ["art", "watercolor"], slug: "whispers-watercolor" },
  { id: 2, title: "Digital Dreamscapes", date: "Mar 28, 2025", excerpt: "How I create dreamy pastel illustrations using Procreate.", tags: ["digital", "tutorial"], slug: "digital-dreamscapes" },
  { id: 3, title: "Finding Creative Flow", date: "Mar 15, 2025", excerpt: "Mindfulness routines that boost artistic productivity.", tags: ["creativity", "wellness"], slug: "creative-flow" }
];

const projects = [
  { title: "Pastel Tarot Deck", description: "78 illustrated cards with dreamy symbolism", year: "2025", slug: "tarot-deck" },
  { title: "Mural at The Rose Café", description: "Large-scale floral abstractions", year: "2024", slug: "rose-cafe-mural" }
];

const publications = [
  { title: "Soft Narratives in Art Journal Quarterly", description: "Essay on pastel aesthetics", publisher: "Art Journal", year: "2025", slug: "soft-narratives" },
  { title: "The Digital Palette", description: "Color psychology for illustrators", publisher: "Creative Press", year: "2024", slug: "digital-palette" }
];
---

<BaseLayout>
  <Hero />
  
  <section>
    <h2 class="page-header">✨ latest from the blog</h2>
    <div id="posts-container" class="grid-blog">
      {blogPosts.map(post => (
        <BlogCard {...post} />
      ))}
    </div>
  </section>
  
  <section>
    <h2 class="page-header">📌 featured projects</h2>
    <div class="two-col-grid">
      {projects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
  
  <section>
    <h2 class="page-header">📄 recent publications</h2>
    <div class="two-col-grid">
      {publications.map(pub => (
        <PublicationCard {...pub} />
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  // Search functionality for dynamic filtering
  function setupDynamicSearch() {
    const searchInput = document.getElementById('search-input');
    if (!searchInput) return;
    
    const filterContent = (term) => {
      const cards = document.querySelectorAll('.blog-card, .project-card, .publication-card');
      cards.forEach(card => {
        const text = card.textContent.toLowerCase();
        const matches = term === '' || text.includes(term.toLowerCase());
        card.style.display = matches ? 'block' : 'none';
      });
    };
    
    window.addEventListener('search', (e) => {
      filterContent(e.detail);
    });
  }
  
  setupDynamicSearch();
</script>